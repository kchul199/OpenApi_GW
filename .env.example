# =============================================================================
# 코인 자동 매매 시스템 - 환경변수 템플릿
# =============================================================================
# 사용 방법:
#   cp .env.example .env
#   # .env 파일을 열고 각 값을 실제 값으로 교체
#
# 주의:
#   - .env 파일은 절대 Git에 커밋하지 마세요 (.gitignore에 포함 필수)
#   - 운영 환경에서는 Docker Secrets 또는 HashiCorp Vault 사용 권장
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16)
# -----------------------------------------------------------------------------
# asyncpg 드라이버 사용 (비동기 SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://cointrader:secret@postgres:5432/cointrader

# PostgreSQL 컨테이너 루트 비밀번호 (docker-compose postgres 서비스)
POSTGRES_PASSWORD=secret

# -----------------------------------------------------------------------------
# Redis Sentinel HA
# -----------------------------------------------------------------------------
# Sentinel 주소 목록 (쉼표 구분, 포트 26379)
REDIS_SENTINEL_HOSTS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379

# Sentinel이 모니터링하는 master 이름 (sentinel.conf의 monitor 이름과 일치)
REDIS_SENTINEL_MASTER=mymaster

# Redis 인증 비밀번호 (requirepass 설정값과 동일)
REDIS_PASSWORD=redispassword

# Celery 브로커 URL (Sentinel 사용 시 sentinel:// 프로토콜)
CELERY_BROKER_URL=sentinel://redis-sentinel-1:26379/0

# Celery 결과 백엔드 (단순 redis:// 사용 가능)
CELERY_RESULT_BACKEND=redis://:redispassword@redis-master:6379/1

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
# HS256 서명 시크릿 (최소 32자 이상의 랜덤 문자열로 교체)
JWT_SECRET_KEY=change-this-secret-key-in-production

# JWT 서명 알고리즘 (HS256 또는 RS256)
JWT_ALGORITHM=HS256

# Access Token 만료 시간 (분)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh Token 만료 시간 (일)
REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# Exchange Settings (거래소 설정)
# -----------------------------------------------------------------------------
# 기본 거래소: binance | upbit | bithumb
EXCHANGE_ID=binance

# 테스트넷 사용 여부 (true = 실제 자금 사용 안 함, 반드시 테스트 시 true)
USE_TESTNET=true

# 기준 통화 (호가 통화)
QUOTE_CURRENCY=USDT

# -----------------------------------------------------------------------------
# Encryption (API Key 암호화)
# -----------------------------------------------------------------------------
# AES-256-GCM 암호화 키 (정확히 32바이트 = 64자 hex 문자열)
# 생성 명령: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=change-this-32-byte-hex-key-here-64chars

# -----------------------------------------------------------------------------
# Claude AI (Anthropic)
# -----------------------------------------------------------------------------
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=your-anthropic-api-key

# 사용할 Claude 모델명 (기본: claude-3-5-sonnet-20241022)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# AI 응답 최대 토큰 수
ANTHROPIC_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# Notification (알림 설정)
# -----------------------------------------------------------------------------
# --- Telegram ---
# BotFather에서 발급한 봇 토큰
TELEGRAM_BOT_TOKEN=

# 알림을 받을 채팅 ID (개인: 숫자, 그룹: -숫자)
TELEGRAM_CHAT_ID=

# --- Email (SMTP) ---
# 발신자 이메일 주소
EMAIL_FROM=

# SMTP 서버 호스트
SMTP_HOST=

# SMTP 포트 (587: STARTTLS, 465: SSL)
SMTP_PORT=587

# SMTP 인증 사용자
SMTP_USER=

# SMTP 인증 비밀번호
SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# 로그 레벨: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
# 브라우저에서 호출하는 API 기본 URL (NEXT_PUBLIC_ 접두사 필수)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
